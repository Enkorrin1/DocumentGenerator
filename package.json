{
  "name": "document-template-generator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node --watch server/index.cjs",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.cjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "carbone": "^3.8.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.2.5",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "pizzip": "^3.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "vite": "^7.1.7"
  }
}
